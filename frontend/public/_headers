# Cache Control Headers for Render Static Site

# HTML files - Never cache (AGGRESSIVE for mobile)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0, s-maxage=0, proxy-revalidate
  Pragma: no-cache
  Expires: 0
  X-Accel-Expires: 0

# Service Worker - Never cache (critical for updates)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0, s-maxage=0, proxy-revalidate
  Pragma: no-cache
  Expires: 0
  X-Accel-Expires: 0

# Manifest - Never cache
/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate, max-age=0

# Static assets with hash - Cache forever (immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images - Cache for 1 week
/*.jpg
  Cache-Control: public, max-age=604800

/*.png
  Cache-Control: public, max-age=604800

/*.webp
  Cache-Control: public, max-age=604800

/*.ico
  Cache-Control: public, max-age=604800

# Fonts - Cache forever
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.ttf
  Cache-Control: public, max-age=31536000, immutable

# Default - No cache
/*
  Cache-Control: no-cache, no-store, must-revalidate
