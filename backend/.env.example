# ========================================
# ACHHADAM BACKEND - ENVIRONMENT VARIABLES
# ========================================
#
# 📋 CLIENT SETUP INSTRUCTIONS:
# 1. Copy this file as ".env" in backend folder
# 2. Replace placeholder values with actual API keys
# 3. Save and restart the server
#
# ⚠️ SECURITY NOTE:
# - Never commit .env file to Git
# - Keep API keys secret
# - Use different keys for dev/production
#
# ========================================

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=production
PORT=5000

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MongoDB Atlas Connection String
# Get from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ========================================
# JWT CONFIGURATION
# ========================================
# Generate secure random strings:
# Node.js: require('crypto').randomBytes(32).toString('hex')
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_MIN_32_CHARACTERS
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_SECURE_RANDOM_STRING
JWT_REFRESH_EXPIRY=7d

# ========================================
# SESSION CONFIGURATION
# ========================================
SESSION_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_FOR_SESSIONS

# ========================================
# CLOUDINARY - IMAGE STORAGE (RECOMMENDED)
# ========================================
# Sign up: https://cloudinary.com
# Get credentials from: Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_ENABLED=true

# ========================================
# RAZORPAY - PAYMENT GATEWAY (REQUIRED FOR PAYMENTS)
# ========================================
# Sign up: https://razorpay.com
# Get keys from: Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxx
RAZORPAY_ENABLED=true

# ========================================
# SMS SERVICE - MSG91 (RECOMMENDED FOR INDIA)
# ========================================
# Sign up: https://msg91.com
# Get auth key from: Dashboard
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_auth_key
MSG91_SENDER_ID=ACHHDM
MSG91_ROUTE=4

# ALTERNATIVE: TWILIO (INTERNATIONAL)
# Sign up: https://twilio.com
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# EMAIL SERVICE - SENDGRID (RECOMMENDED)
# ========================================
# Sign up: https://sendgrid.com
# Generate API key from: Settings > API Keys
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ALTERNATIVE: AWS SES
# EMAIL_PROVIDER=ses
# AWS_SES_ACCESS_KEY=AKIA...
# AWS_SES_SECRET_KEY=your_secret_key
# AWS_SES_REGION=ap-south-1

# ========================================
# GOOGLE MAPS API (FOR LOCATION FEATURES)
# ========================================
# Create project: https://console.cloud.google.com
# Enable: Maps JavaScript API, Geocoding API, Places API
GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxx
GOOGLE_MAPS_ENABLED=true

# ========================================
# WEATHER API (FOR CROP ADVISORY)
# ========================================
# Sign up: https://openweathermap.org
WEATHER_PROVIDER=openweather
OPENWEATHER_API_KEY=your_api_key

# ALTERNATIVE: https://weatherapi.com
# WEATHER_PROVIDER=weatherapi
# WEATHER_API_KEY=your_api_key

# ========================================
# FIREBASE - PUSH NOTIFICATIONS (OPTIONAL)
# ========================================
# Create project: https://console.firebase.google.com
# Download service account JSON and extract:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_ENABLED=true

# ========================================
# OPENAI - AI FEATURES (OPTIONAL)
# ========================================
# Sign up: https://platform.openai.com
# Get API key from: API Keys section
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_ENABLED=true

# ========================================
# AWS S3 - FILE STORAGE (ALTERNATIVE TO CLOUDINARY)
# ========================================
# Create S3 bucket and IAM user with S3 permissions
AWS_S3_ENABLED=false
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name

# ========================================
# ANALYTICS (OPTIONAL)
# ========================================
# Google Analytics
# Create property: https://analytics.google.com
GA_TRACKING_ID=G-XXXXXXXXXX
GA_ENABLED=true

# Mixpanel
# Create project: https://mixpanel.com
MIXPANEL_TOKEN=your_token
MIXPANEL_ENABLED=false

# ========================================
# FIREBASE CONFIGURATION (FOR AUTHENTICATION)
# ========================================
FIREBASE_PROJECT_ID=digital-farming-platform

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
OTP_RATE_LIMIT_WINDOW_MS=60000
OTP_RATE_LIMIT_MAX_REQUESTS=10

# ========================================
# CORS CONFIGURATION
# ========================================
# Add client's production domain
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com,https://www.yourdomain.com

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_DIR=logs

# ========================================
# SECURITY
# ========================================
BCRYPT_ROUNDS=12
HELMET_CSP_ENABLED=false

# ========================================
# DEVELOPMENT SETTINGS (DISABLE IN PRODUCTION)
# ========================================
DEBUG_MODE=false
MOCK_OTP_ENABLED=false
