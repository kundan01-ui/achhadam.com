// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRESQL_URL")
}

// User Management
model User {
  id                String   @id @default(cuid())
  email             String   @unique
  phone             String   @unique
  password          String
  role              UserRole @default(FARMER)
  status            UserStatus @default(PENDING)
  isEmailVerified   Boolean  @default(false)
  isPhoneVerified   Boolean  @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Profile relationships
  profile           Profile?
  documents         Document[]
  sessions          Session[]
  notifications     Notification[]
  orders           Order[]
  transactions     Transaction[]
  supportTickets   SupportTicket[]

  @@map("users")
}

enum UserRole {
  FARMER
  BUYER
  TRANSPORTER
  ADMIN
  MODERATOR
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

// User Profiles
model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  gender            Gender?
  profilePicture    String?
  address           Address?
  bankDetails       BankDetails?
  
  // Role-specific fields
  farmerProfile     FarmerProfile?
  buyerProfile      BuyerProfile?
  transporterProfile TransporterProfile?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// Address
model Address {
  id                String   @id @default(cuid())
  profileId         String   @unique
  street            String
  city              String
  state             String
  district          String
  tehsil            String
  village           String?
  pincode           String
  latitude          Float?
  longitude         Float?
  isDefault         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// Bank Details
model BankDetails {
  id                String   @id @default(cuid())
  profileId         String   @unique
  accountNumber     String
  ifscCode          String
  bankName          String
  accountHolderName String
  accountType       AccountType
  isVerified        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("bank_details")
}

enum AccountType {
  SAVINGS
  CURRENT
  BUSINESS
}

// Farmer Profile
model FarmerProfile {
  id                String   @id @default(cuid())
  profileId         String   @unique
  farmName          String
  farmSize          Float
  farmSizeUnit      FarmSizeUnit
  farmType          FarmType[]
  crops             String[]
  experience        Int      // Years of farming experience
  certifications    String[]
  organicCertified  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("farmer_profiles")
}

enum FarmSizeUnit {
  ACRES
  HECTARES
  BIGHAS
  KANALS
}

enum FarmType {
  IRRIGATED
  RAINFED
  MIXED
  ORGANIC
  HYDROPONIC
  VERTICAL
}

// Buyer Profile
model BuyerProfile {
  id                String   @id @default(cuid())
  profileId         String   @unique
  businessName      String
  businessType      BusinessType
  gstNumber         String?
  gstVerified       Boolean  @default(false)
  creditLimit       Float?
  paymentTerms      Int      // Days
  preferredCrops    String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("buyer_profiles")
}

enum BusinessType {
  INDIVIDUAL
  PARTNERSHIP
  PRIVATE_LIMITED
  PUBLIC_LIMITED
  COOPERATIVE
  GOVERNMENT
}

// Transporter Profile
model TransporterProfile {
  id                String   @id @default(cuid())
  profileId         String   @unique
  companyName       String?
  serviceAreas      String[]
  vehicleTypes      VehicleType[]
  licenses          String[]
  insurance         InsuranceDetails?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("transporter_profiles")
}

enum VehicleType {
  TRUCK
  TRAILER
  PICKUP
  TEMPO
  MINI_TRUCK
  REFRIGERATED
}

// Insurance Details
model InsuranceDetails {
  id                String   @id @default(cuid())
  transporterProfileId String @unique
  policyNumber      String
  insuranceCompany  String
  validFrom         DateTime
  validTo           DateTime
  coverageAmount    Float
  premiumAmount     Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transporterProfile TransporterProfile @relation(fields: [transporterProfileId], references: [id], onDelete: Cascade)

  @@map("insurance_details")
}

// Documents
model Document {
  id                String   @id @default(cuid())
  userId            String
  documentType      DocumentType
  documentNumber    String?
  fileUrl           String
  fileName          String
  fileSize          Int
  mimeType          String
  isVerified        Boolean  @default(false)
  verifiedBy        String?
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("documents")
}

enum DocumentType {
  AADHAR
  PAN
  VOTER_ID
  DRIVING_LICENSE
  VEHICLE_RC
  INSURANCE
  CERTIFICATION
  OTHER
}

// Sessions
model Session {
  id                String   @id @default(cuid())
  userId            String
  token             String   @unique
  deviceInfo        String?
  ipAddress         String?
  expiresAt         DateTime
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// Notifications
model Notification {
  id                String   @id @default(cuid())
  userId            String
  title             String
  message           String
  type              NotificationType
  isRead            Boolean  @default(false)
  readAt            DateTime?
  data              Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  ORDER_UPDATE
  PAYMENT
  SYSTEM
  MARKETING
  SECURITY
}

// Orders
model Order {
  id                String   @id @default(cuid())
  orderNumber       String   @unique
  buyerId           String
  sellerId          String
  status            OrderStatus @default(PENDING)
  totalAmount       Float
  currency          String   @default("INR")
  paymentStatus     PaymentStatus @default(PENDING)
  deliveryAddress   String
  expectedDelivery  DateTime?
  actualDelivery    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  buyer             User     @relation(fields: [buyerId], references: [id])
  orderItems        OrderItem[]
  transactions      Transaction[]
  supportTickets    SupportTicket[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// Order Items
model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  cropName          String
  quantity          Float
  unit              String
  unitPrice         Float
  totalPrice        Float
  qualityGrade      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// Transactions
model Transaction {
  id                String   @id @default(cuid())
  userId            String
  orderId           String?
  type              TransactionType
  amount            Float
  currency          String   @default("INR")
  status            TransactionStatus @default(PENDING)
  paymentMethod     PaymentMethod?
  gatewayResponse   Json?
  referenceId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  order             Order?   @relation(fields: [orderId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  PAYMENT
  REFUND
  COMMISSION
  WITHDRAWAL
  DEPOSIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
  COD
  BANK_TRANSFER
}

// Support Tickets
model SupportTicket {
  id                String   @id @default(cuid())
  userId            String
  orderId           String?
  subject           String
  description       String
  priority          TicketPriority @default(MEDIUM)
  status            TicketStatus @default(OPEN)
  category          TicketCategory
  assignedTo        String?
  resolvedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  order             Order?   @relation(fields: [orderId], references: [id])

  @@map("support_tickets")
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketCategory {
  TECHNICAL
  BILLING
  ORDER
  ACCOUNT
  GENERAL
}

